{
  "name": "vmss-website",
  "version": "1.0.0",
  "private": true,
  "description": "The Five Rings — VMSS doctrine portal (static site). Tailwind is compiled ahead of time; run build:css after changing classes in HTML/JS.",
  "scripts": {
    "build:css": "tailwindcss -i tailwind.input.css -o assets/css/tailwind.css --minify",
    "build:certification": "node tools/build-path2-certification-page.mjs",
    "build:path2-record": "node tools/build-path2-record-annexes.mjs",
    "check:certification": "node tools/verify-path2-certification-2294.mjs",
    "check:path2-record": "node tools/verify-path2-record-annexes.mjs && node tools/build-path2-record-annexes.mjs --check",
    "test:certification": "node tools/test-path2-certification-mutations.mjs",
    "test:code-guards": "node tools/test-code-founding-guards.mjs",
    "check:canon": "node tools/check-canon.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
